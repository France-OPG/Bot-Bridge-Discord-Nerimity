# ============================================================
#  NERIMITY ↔ DISCORD BRIDGE — Configuration
# ============================================================

# --- Discord ---
# Token du bot Discord (depuis discord.com/developers/applications)
DISCORD_TOKEN=ton_token_discord_ici
# ID du serveur Discord à bridger
DISCORD_GUILD_ID=123456789012345678

# --- Nerimity ---
# Token du bot Nerimity (depuis les paramètres de ton compte Nerimity)
NERIMITY_TOKEN=ton_token_nerimity_ici
# ID du serveur Nerimity à bridger
NERIMITY_SERVER_ID=123456789012345678

# --- Bridge ---
# Préfixe affiché pour les messages (ex: "[Discord] pseudo: message")
BRIDGE_PREFIX_DISCORD=[Discord]
BRIDGE_PREFIX_NERIMITY=[Nerimity]

# Activer le bridge vocal (true/false)
VOICE_BRIDGE_ENABLED=true

# --- Optionnel ---
# Niveau de logs : error | warn | info | debug
LOG_LEVEL=info
